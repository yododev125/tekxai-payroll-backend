generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & RBAC ──────────────────────────────────────────────────────────────

model users {
  id            String    @id @default(cuid())
  email         String    @unique
  password_hash String
  first_name    String?
  last_name     String?
  phone         String?
  avatar        String?
  department_id String?
  division_id   String?
  position      String?
  designation   String?
  employee_id   String?   @unique
  status        String    @default("ACTIVE")
  is_active     Boolean   @default(true)
  hire_date     DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  roles                    user_roles[]
  refresh_tokens           auth_refresh_tokens[]
  otp_codes                otp_codes[]
  settings                 user_settings?
  department               departments?                  @relation(fields: [department_id], references: [id], onDelete: SetNull)
  division                 divisions?                    @relation(fields: [division_id],   references: [id], onDelete: SetNull)
  team_memberships         team_members[]
  managed_teams            teams[]                       @relation("team_manager")
  owned_projects           projects[]                    @relation("project_owner")
  led_projects             projects[]                    @relation("project_leader")
  project_memberships      project_members[]
  timesheet_entries        timesheet_entries[]
  time_off_requests        time_off_requests[]
  timesheet_edit_requests  timesheet_edit_requests[]
  invites_sent             invites[]                     @relation("invite_sender")
  redeemed_invite          invites?                      @relation("invite_redeemed_by")
  starred_items            starred_items[]
  notifications            notifications[]
  support_tickets          support_tickets[]
  marketing_deals          marketing_deals[]
  salary_builders          salary_builders[]
  asset_assignments        asset_assignments[]
  daily_reports            daily_progress_reports[]
  performance_scores       employee_performance_scores[]
  performance_reviews      performance_reviews[]

  @@index([department_id])
  @@index([division_id])
  @@index([status])
}

model roles {
  id         String       @id @default(cuid())
  name       String       @unique
  level      Int
  is_system  Boolean      @default(false)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  users   user_roles[]
  invites invites[]
}

model user_roles {
  user_id     String
  role_id     String
  assigned_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role roles @relation(fields: [role_id], references: [id], onDelete: Restrict)

  @@id([user_id, role_id])
  @@index([role_id])
}

model auth_refresh_tokens {
  id                     String    @id @default(cuid())
  user_id                String
  token_hash             String    @unique
  expires_at             DateTime
  revoked_at             DateTime?
  replaced_by_token_hash String?
  created_by_ip          String?
  created_by_user_agent  String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model otp_codes {
  id         String    @id @default(cuid())
  user_id    String
  code       String
  purpose    String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

// ─── Org Structure ────────────────────────────────────────────────────────────

model departments {
  id          String    @id @default(cuid())
  name        String
  code        String?   @unique
  description String?
  manager_id  String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  divisions divisions[]
  users     users[]
  teams     teams[]
  assets    assets[]
}

model divisions {
  id            String    @id @default(cuid())
  department_id String
  name          String
  code          String?   @unique
  description   String?
  manager_id    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  department departments @relation(fields: [department_id], references: [id], onDelete: Cascade)
  users      users[]
  teams      teams[]
}

// ─── User Settings ────────────────────────────────────────────────────────────

model user_settings {
  id                 String   @id @default(cuid())
  user_id            String   @unique
  show_notifications Boolean  @default(true)
  language           String   @default("en")
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ─── Teams ────────────────────────────────────────────────────────────────────

model teams {
  id            String    @id @default(cuid())
  name          String
  description   String?
  type          String    @default("GENERAL")
  department_id String?
  division_id   String?
  manager_id    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  department departments? @relation(fields: [department_id], references: [id], onDelete: SetNull)
  division   divisions?   @relation(fields: [division_id],   references: [id], onDelete: SetNull)
  manager    users?       @relation("team_manager", fields: [manager_id], references: [id], onDelete: SetNull)
  members    team_members[]
  projects   projects[]
  invites    invites[]

  @@index([department_id])
}

model team_members {
  id        String   @id @default(cuid())
  team_id   String
  user_id   String
  role      String   @default("MEMBER")
  joined_at DateTime @default(now())

  team teams @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@index([team_id])
  @@index([user_id])
}

// ─── Projects ────────────────────────────────────────────────────────────────

model projects {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("PENDING")
  progress    Int       @default(0)
  total_hours Int       @default(0)
  start_date  DateTime?
  end_date    DateTime?
  owner_id    String?
  leader_id   String?
  team_id     String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  owner       users?           @relation("project_owner",  fields: [owner_id],  references: [id], onDelete: SetNull)
  team_leader users?           @relation("project_leader", fields: [leader_id], references: [id], onDelete: SetNull)
  team        teams?           @relation(fields: [team_id], references: [id], onDelete: SetNull)
  members     project_members[]
  tasks       tasks[]
  milestones  milestones[]
  starred_by  starred_items[]

  @@index([owner_id])
  @@index([status])
}

model project_members {
  id         String   @id @default(cuid())
  project_id String
  user_id    String
  role       String   @default("MEMBER")
  joined_at  DateTime @default(now())

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    users    @relation(fields: [user_id],    references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@index([project_id])
  @@index([user_id])
}

model tasks {
  id          String    @id @default(cuid())
  project_id  String
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  assigned_to String?
  due_date    DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([status])
}

model milestones {
  id          String    @id @default(cuid())
  project_id  String
  title       String
  description String?
  due_date    DateTime?
  completed   Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

// ─── Starred Items ────────────────────────────────────────────────────────────

model starred_items {
  id         String   @id @default(cuid())
  user_id    String
  item_type  String
  item_id    String
  project_id String?
  created_at DateTime @default(now())

  user    users     @relation(fields: [user_id],    references: [id], onDelete: Cascade)
  project projects? @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@unique([user_id, item_type, item_id])
  @@index([user_id])
  @@index([item_type])
}

// ─── Timesheets ───────────────────────────────────────────────────────────────

model timesheet_entries {
  id           String    @id @default(cuid())
  user_id      String
  check_in     DateTime
  check_out    DateTime?
  duration_sec Int       @default(0)
  status       String    @default("IN_PROGRESS")
  note         String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  user          users                     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  edit_requests timesheet_edit_requests[]

  @@index([user_id])
  @@index([check_in])
  @@index([status])
}

model timesheet_edit_requests {
  id            String    @id @default(cuid())
  entry_id      String
  user_id       String
  new_check_in  DateTime?
  new_check_out DateTime?
  reason        String
  status        String    @default("PENDING")
  reviewed_by   String?
  reviewed_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  entry timesheet_entries @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  user  users             @relation(fields: [user_id],  references: [id], onDelete: Cascade)

  @@index([entry_id])
  @@index([user_id])
  @@index([status])
}

model time_off_policies {
  id           String   @id @default(cuid())
  name         String
  description  String?
  days_allowed Int      @default(0)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  requests time_off_requests[]
}

model time_off_requests {
  id              String    @id @default(cuid())
  user_id         String
  policy_id       String
  start_date      DateTime
  end_date        DateTime
  days            Int       @default(1)
  reason          String
  status          String    @default("PENDING")
  manager_comment String?
  reviewed_by     String?
  reviewed_at     DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user   users             @relation(fields: [user_id],   references: [id], onDelete: Cascade)
  policy time_off_policies @relation(fields: [policy_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([status])
}

// ─── Invites ─────────────────────────────────────────────────────────────────

model invites {
  id              String    @id @default(cuid())
  email           String
  token           String    @unique @default(cuid())
  role_id         String
  team_id         String?
  department      String?
  designation     String?
  status          String    @default("PENDING")
  invited_by      String
  expires_at      DateTime
  used_at         DateTime?
  redeemed_by_id  String?   @unique
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  role          roles  @relation(fields: [role_id],         references: [id], onDelete: Restrict)
  team          teams? @relation(fields: [team_id],         references: [id], onDelete: SetNull)
  inviter       users  @relation("invite_sender",           fields: [invited_by], references: [id], onDelete: Cascade)
  redeemed_by   users? @relation("invite_redeemed_by",      fields: [redeemed_by_id], references: [id])

  @@index([email])
  @@index([token])
  @@index([status])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model notifications {
  id         String   @id @default(cuid())
  user_id    String
  title      String
  message    String
  type       String   @default("info")
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
}

// ─── Support Tickets ─────────────────────────────────────────────────────────

model support_tickets {
  id              String    @id @default(cuid())
  ticket_number   String    @unique
  subject         String
  description     String
  recipient_role  String
  recipient_label String
  recipient_name  String
  status          String    @default("pending")
  priority        String    @default("medium")
  user_id         String
  resolution_note String?
  resolved_at     DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
}

// ─── Marketing ───────────────────────────────────────────────────────────────

model marketing_deals {
  id             String   @id @default(cuid())
  date           DateTime
  salesperson_id String
  source         String
  lead_job       String
  contact        String?
  team_label     String
  revenue_usd    Float    @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  salesperson users @relation(fields: [salesperson_id], references: [id], onDelete: Cascade)

  @@index([salesperson_id])
}

model salary_builders {
  id               String    @id @default(cuid())
  user_id          String
  period           String
  team_label       String
  status           String    @default("draft")
  basic_salary_pkr Float     @default(0)
  deductions_pkr   Float     @default(0)
  deduction_reason String?
  commission_pkr   Float     @default(0)
  allowances       Json      @default("[]")
  published_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, period])
  @@index([user_id])
  @@index([status])
}

// ─── Asset Management ─────────────────────────────────────────────────────────

model asset_categories {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  assets assets[]
}

model asset_vendors {
  id           String   @id @default(cuid())
  name         String
  contact_info String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  assets assets[]
}

model asset_locations {
  id          String   @id @default(cuid())
  office      String
  floor       String?
  room        String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  assets assets[]
}

model assets {
  id              String    @id @default(cuid())
  asset_tag       String    @unique
  name            String
  brand           String?
  model           String?
  serial_number   String?
  category_id     String
  vendor_id       String?
  location_id     String?
  department_id   String?
  status          String    @default("AVAILABLE")
  purchase_date   DateTime?
  purchase_cost   Float?
  warranty_expiry DateTime?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  category    asset_categories @relation(fields: [category_id], references: [id], onDelete: Restrict)
  vendor      asset_vendors?   @relation(fields: [vendor_id],   references: [id], onDelete: SetNull)
  location    asset_locations? @relation(fields: [location_id], references: [id], onDelete: SetNull)
  department  departments?     @relation(fields: [department_id], references: [id], onDelete: SetNull)
  assignments asset_assignments[]
  maintenance asset_maintenance_logs[]
  disposals   asset_disposals[]

  @@index([category_id])
  @@index([status])
  @@index([department_id])
}

model asset_assignments {
  id                String    @id @default(cuid())
  asset_id          String
  user_id           String
  assigned_at       DateTime  @default(now())
  return_date       DateTime?
  returned_at       DateTime?
  returned_condition String?
  notes             String?
  assigned_by       String?
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  asset assets @relation(fields: [asset_id], references: [id], onDelete: Cascade)
  user  users  @relation(fields: [user_id],  references: [id], onDelete: Cascade)

  @@index([asset_id])
  @@index([user_id])
  @@index([is_active])
}

model asset_maintenance_logs {
  id            String   @id @default(cuid())
  asset_id      String
  type          String
  description   String
  cost          Float?
  performed_by  String?
  performed_at  DateTime @default(now())
  next_due_date DateTime?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  asset assets @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@index([asset_id])
}

model asset_disposals {
  id            String   @id @default(cuid())
  asset_id      String
  reason        String
  disposal_date DateTime
  disposed_by   String?
  notes         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  asset assets @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@index([asset_id])
}

// ─── Performance Management ───────────────────────────────────────────────────

model daily_progress_reports {
  id                    String    @id @default(cuid())
  user_id               String
  project_id            String?
  task_id               String?
  date                  DateTime  @default(now())
  todays_progress       String
  completion_percentage Int       @default(0)
  blockers              String?
  tomorrow_plan         String?
  manager_remarks       String?
  status                String    @default("SUBMITTED")
  reviewed_by           String?
  reviewed_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([date])
  @@index([status])
}

model employee_performance_scores {
  id              String   @id @default(cuid())
  user_id         String
  period          String
  score_type      String   @default("ENGINEERING")
  timely_delivery Int      @default(0)
  quality_score   Int      @default(0)
  regularity      Int      @default(0)
  punctuality     Int      @default(0)
  dress_code      Int      @default(0)
  total_score     Int      @default(0)
  notes           String?
  scored_by       String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, period])
  @@index([user_id])
  @@index([period])
}

model performance_reviews {
  id          String   @id @default(cuid())
  user_id     String
  reviewer_id String
  period      String
  rating      Int      @default(0)
  comments    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user     users @relation(fields: [user_id],     references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([period])
}

model bonus_configurations {
  id              String   @id @default(cuid())
  level_name      String
  min_score       Int
  max_score       Int
  bonus_amount    Float    @default(0)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model monthly_bonus_records {
  id              String    @id @default(cuid())
  user_id         String
  period          String
  average_score   Float     @default(0)
  performance_level String?
  bonus_eligible  Boolean   @default(false)
  bonus_amount    Float     @default(0)
  approval_status String    @default("PENDING")
  approved_by     String?
  approved_at     DateTime?
  paid_at         DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@unique([user_id, period])
  @@index([user_id])
  @@index([period])
  @@index([approval_status])
}
