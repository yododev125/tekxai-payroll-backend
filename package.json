{
  "name": "tekxai-management-be",
  "version": "2.0.0",
  "description": "Tekxai ERP Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "start:dev": "NODE_ENV=development node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "dev": "NODE_ENV=development node --watch src/server.js",
    "db:generate": "prisma generate",
    "db:migrate:dev": "NODE_ENV=development prisma migrate dev",
    "db:migrate:prod": "NODE_ENV=production prisma migrate deploy",
    "db:push": "NODE_ENV=development prisma db push",
    "db:studio": "NODE_ENV=development prisma studio",
    "db:reset": "NODE_ENV=development prisma migrate reset",
    "db:seed": "NODE_ENV=development node prisma/seeders/index.js",
    "test": "node --test tests/**/*.test.js"
  },
  "prisma": {
    "seed": "node prisma/seeders/index.js"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
